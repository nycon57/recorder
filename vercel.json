{
  "crons": [
    {
      "path": "/api/admin/storage/schedule-migrations",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/collect-metrics",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/generate-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/generate-recommendations",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/perform-health-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/generate-weekly-digest",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/wiki-lint",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/wiki-clusters",
      "schedule": "0 4 * * 0"
    }
  ]
}

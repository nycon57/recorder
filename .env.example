# ============================================================
# Tribora — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================

# === App ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=http://localhost:3000

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DIRECT_DATABASE_URL=

# === Better Auth ===
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# === Stripe ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# === Sentry ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=truetone-ai
SENTRY_PROJECT=tribora

# === PostHog ===
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Email (Resend) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_EMAIL=

# === Rate Limiting (Upstash Redis) ===
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === AI — Google ===
GOOGLE_AI_API_KEY=
GOOGLE_API_KEY=

# === AI — OpenAI ===
OPENAI_API_KEY=
OPENAI_ORG_ID=

# === OAuth — Google ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# === Google Cloud (optional — for Speech/TTS) ===
GOOGLE_CREDENTIALS_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=

# === Bot Protection ===
BOTID_API_KEY=

# === Storage (Cloudflare R2) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=recorder-storage
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_REGION=auto

# === Cron ===
CRON_SECRET=

# === Microsoft Integrations (optional) ===
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=

# === Zoom Integration (optional) ===
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# === Cohere Reranking (optional) ===
COHERE_API_KEY=

# === Webhooks ===
WEBHOOK_SECRET=

# === Vercel (auto-set on Vercel) ===
# VERCEL_REVALIDATE_TOKEN=
# NEXT_PUBLIC_ANALYTICS_ID=

# === Cloudflare (optional — edge cache purge) ===
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=

# === Worker Tuning (optional) ===
# JOB_BATCH_SIZE=10
# JOB_POLL_INTERVAL_MS=2000
# JOB_MAX_POLL_INTERVAL_MS=10000
# JOB_MAX_RETRIES=3
# JOB_DEAD_LETTER_RETRIES=5
# JOB_TIMEOUT_MS=14400000
# JOB_MEMORY_WARNING_PERCENT=80

# === Search Tuning (optional) ===
# SEARCH_DEFAULT_THRESHOLD=0.5
# SEARCH_ENABLE_HYBRID=true
# SEARCH_ENABLE_QUERY_EXPANSION=true
# MAX_SUBQUERIES=5
# AGENTIC_MAX_ITERATIONS=3
# AGENTIC_CONFIDENCE_THRESHOLD=0.75
# ENABLE_SELF_REFLECTION=true
# ENABLE_AGENTIC_RAG=true
# ENABLE_RERANKING=true
# ENABLE_CHAT_TOOLS=true
# ENABLE_SEARCH_MONITORING=false
# ENABLE_SEARCH_AB_TESTING=false
# ENABLED_SEARCH_VARIANTS=

# === Frame Extraction (optional) ===
# FRAME_EXTRACTION_FPS=0.5
# FRAME_EXTRACTION_MAX_FRAMES=300
# FRAME_QUALITY=85
# FRAMES_STORAGE_BUCKET=video-frames
# ENABLE_FRAME_DESCRIPTIONS=true
# ENABLE_OCR=false
# ENABLE_VISUAL_SEARCH=false

# === Semantic Chunking (optional) ===
# SEMANTIC_CHUNK_MIN_SIZE=200
# SEMANTIC_CHUNK_MAX_SIZE=800
# SEMANTIC_CHUNK_TARGET_SIZE=500
# SEMANTIC_SIMILARITY_THRESHOLD=0.85
# SENTENCE_TRANSFORMER_MODEL=Xenova/all-MiniLM-L6-v2

# === OCR (optional) ===
# OCR_CONFIDENCE_THRESHOLD=70
# OCR_POOL_SIZE=4
# TESSERACT_WORKER_PATH=
# TESSERACT_LANG_PATH=
# TESSERACT_CORE_PATH=

# === Logging (optional) ===
# LOG_LEVEL=info
# DEBUG_CHAT_STREAM=false

# === AI Models (optional — override defaults) ===
# DOCIFY_MODEL=
# CHAT_MODEL=

# === Scheduler (optional) ===
# CURATOR_SCHEDULE_INTERVAL_MS=
# GAP_ANALYSIS_SCHEDULE_INTERVAL_MS=

# === Agent Metering (optional) ===
# CREDITS_PER_1K_TOKENS=

# === Cache (optional — legacy Redis) ===
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# === Search Metrics (optional) ===
# SEARCH_METRICS_STORAGE=memory
# SEARCH_METRICS_BUFFER_SIZE=100
# SEARCH_METRICS_TTL=86400

# === Visual Indexing (optional) ===
# VISUAL_INDEXING_BATCH_SIZE=20
